# Grafana endpoint
GRAFANA_URL=https://grafana.example.com

# Auth
# Option A: single token (works for one org)
GRAFANA_TOKEN=
# Option B: basic auth (admin account, can work across orgs)
GRAFANA_USER=reader
GRAFANA_PASS=pass
# Option C: per-org service account tokens (space-separated org=token pairs)
# GRAFANA_ORG_TOKENS="1=token_org1 2=token_org2 3=token_org3"
# If GRAFANA_ORG_TOKENS is set, each org from GRAFANA_ORG_IDS must have a token.

# Dashboard sync defaults
GRAFANA_ORG_IDS=1 2 3
GRAFANA_DASH_GET_ORGID=1
GRAFANA_DASH_UID=darwin-exporter-overview
GRAFANA_DASH_PATH=docs/grafana/dashboard.json

# Extra args for scripts/grafana-dashboard-sync.sh (optional)
# GRAFANA_SYNC_ARGS=--insecure
