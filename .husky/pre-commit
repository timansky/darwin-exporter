#!/usr/bin/env bash
set -euo pipefail

echo "Running markdownlint, eslint, and golangci-lint..."
make lint

echo "Running yamllint..."
if git ls-files -- "*.yml" "*.yaml" | grep -q .; then
  git ls-files -- "*.yml" "*.yaml" | xargs yamllint -c .yamllint
fi

echo "Running go vet..."
go vet ./...

echo "Running go test..."
go test ./...
